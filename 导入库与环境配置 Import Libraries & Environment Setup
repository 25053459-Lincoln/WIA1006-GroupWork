from google.colab import files
import zipfile
import pandas as pd
import os

# 上传 ZIP 文件 Upload a ZIP file
print("Please upload your archive.zip file:")
uploaded = files.upload()
zip_filename = next(iter(uploaded.keys()))

# 解压 ZIP 文件 Extract the ZIP file
with zipfile.ZipFile(zip_filename, 'r') as zip_ref:
    zip_ref.extractall('/content/')
print("Extraction completed!")

# 自动识别并读取主数据集 Automatically identify and read the main dataset
csv_files = [f for f in os.listdir('/content/') if f.endswith('.csv')]

# 选文件最大的那个作为主数据集 Select the largest file as the main dataset 
main_csv = max(csv_files, key=lambda x: os.path.getsize(f"/content/{x}"))
df = pd.read_csv(f"/content/{main_csv}")

print(f"\nSuccessfully loaded main dataset: {main_csv}")
print("Data shape:", df.shape)
display(df.head())

