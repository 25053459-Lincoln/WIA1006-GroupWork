# 3.4 处理异常值（IQR法） Treatment of outliers (IQR method)
# 【注意】因为合成数据的不稳定，我建议你暂时只对使用时间等不太影响最终分布的列去极值
print("\n4. Handling outliers (IQR method)")
def remove_outliers(data, col):
    Q1 = data[col].quantile(0.25)
    Q3 = data[col].quantile(0.75)
    IQR = Q3 - Q1
    lower = Q1 - 1.5 * IQR
    upper = Q3 + 1.5 * IQR
    return data[(data[col] >= lower) & (data[col] <= upper)]

# 先只对 usage_time 处理，防止误删正常数据影响类别比例
for col in ['app_usage_time_min']:
    if col in df.columns:
        before = df.shape[0]
        df = remove_outliers(df, col)
        after = df.shape[0]
        print(f"  {col}: Removed {before - after} outliers")

print(f"\n Data cleaning completed! Final data shape: {df.shape}")


