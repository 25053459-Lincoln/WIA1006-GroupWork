# 3.3 处理异常值（IQR法） Treatment of outliers (IQR method) 

print("\n3. Handling outliers (IQR method)")
def remove_outliers(data, col):
    Q1 = data[col].quantile(0.25)
    Q3 = data[col].quantile(0.75)
    IQR = Q3 - Q1
    lower = Q1 - 1.5 * IQR
    upper = Q3 + 1.5 * IQR
    return data[(data[col] >= lower) & (data[col] <= upper)]

# 对关键数值列去异常 Remove outliers for key numeric columns
for col in ['app_usage_time_min', 'swipe_right', 'likes_received', 'mutual_matches']:
    if col in df.columns:
        before = df.shape[0]
        df = remove_outliers(df, col)
        after = df.shape[0]
        print(f"  {col}: Removed {before - after} outliers")

# 3.4 过滤无效分类值（针对match_outcome） Filter invalid categorical values (for match_outcome)
if 'match_outcome' in df.columns:
    valid_outcomes = ['Mutual Match', 'Ghosted', 'Catfished', 'No Match']
    df = df[df['match_outcome'].isin(valid_outcomes)]
    print("\n Invalid match_outcome values have been filtered!")

print(f"\n Data cleaning completed! Final data shape: {df.shape}")


